APP_NAME="Harsha Portfolio API"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:8000

# ── Security ────────────────────────────────────────────────────
# Leave empty in local dev (disables API key check)
API_KEY=your_secure_random_api_key_here

# ── CORS — set to your Vercel URL in production ─────────────────
FRONTEND_URL=http://localhost:3000

# ── Database (Supabase PostgreSQL) ─────────────────────────────
# Get these by clicking "Connect" in your Supabase project dashboard
# Use the "Session pooler" connection string for Render.com
DB_CONNECTION=pgsql
DB_HOST=aws-0-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your_project_ref
DB_PASSWORD=your_supabase_db_password

# ── Mail (Gmail SMTP) ────────────────────────────────────────────
# Use a Gmail App Password — NOT your Gmail account password
# How to get App Password: Google Account → Security → 2FA → App Passwords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_gmail@gmail.com
MAIL_FROM_NAME="Harsha Portfolio"

# Where contact form emails are delivered:
MAIL_PORTFOLIO_RECIPIENT=harsha230302@gmail.com

# ── Cache / Queue ────────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
LOG_CHANNEL=stack
LOG_LEVEL=error
